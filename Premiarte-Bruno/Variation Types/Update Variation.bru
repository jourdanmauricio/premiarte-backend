meta {
  name: Update Variation
  type: http
  seq: 3
}

put {
  url: {{url}}/variation-types/1
  body: json
  auth: inherit
}

body:json {
    {
      "name": "Colores",
      "values": [
        {
          "id": 2,
          "value": "Azul"
        },
        {
          "id": 1,
          "value": "Rojo"
        }
      ]
    }
}

script:pre-request {
  req.setHeader("Authorization", "Bearer {{access_token}}");
}

settings {
  encodeUrl: true
  timeout: 0
}
